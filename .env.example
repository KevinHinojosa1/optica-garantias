# Base de datos (reprogramaciones, clientes, historial, conocimiento)
# Local (por defecto): SQLite en data/optica_garantias.db
DATABASE_URL=sqlite:///./data/optica_garantias.db

# PostgreSQL (recomendado en Render/producción para que no se pierda al redesplegar)
# DATABASE_URL=postgresql+psycopg://optica:optica123@localhost:5432/optica_garantias

# Claude API (análisis de imagen — proveedor principal)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
VISION_PROVIDER=claude

# xAI API (alternativa — grok-2-vision)
XAI_API_KEY=your_xai_api_key_here
XAI_API_BASE=https://api.x.ai/v1
XAI_VISION_MODEL=grok-2-vision-1212

# Aplicación
APP_NAME=Óptica Los Andes - Gestión de Garantías
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Asesor por defecto (para historial)
DEFAULT_ASESOR=Kevin Hinojosa

# Google Sheets — verificación IVR (opcional)
# Local: archivo JSON de cuenta de servicio
GOOGLE_CREDENTIALS_PATH=data/google/credentials.json
# Producción (Render): pegar el JSON completo en una sola línea
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_IVR_NAME=IVR Verificaciones

# WhatsApp Business Cloud API (reprogramación de entregas — envío automático)
# Token permanente de la app Meta + ID del número de teléfono Business
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Correo SMTP opcional (reprogramaciones a tienda). Sin esto se usa copiar / mailto.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true